# ─── Server ─────────────────────────────────────────────────────────────────
PORT=4000

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Thay bằng chuỗi ngẫu nhiên mạnh ≥ 32 ký tự (vd: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_32CHARS
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_STRONG_RANDOM_SECRET
JWT_EXPIRATION=1d

# ─── MySQL ───────────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=healthhub

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/healthhub

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (Gmail App Password) ───────────────────────────────────────────────
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_gmail_app_password

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── Admin Seed ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@healthhub.com
ADMIN_PASSWORD=Admin@123456

# ─── CORS ────────────────────────────────────────────────────────────────────
# Danh sách origin được phép, cách nhau bằng dấu phẩy
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
